{
  "name": "opencode-skill-basis",
  "version": "1.0.0",
  "description": "Core framework and foundation for all skills in the KI-Dev-Agent ecosystem - skill loader, configuration, and common utilities",
  "author": "KI-Dev-Agent Team",
  "created": "2026-03-11",
  "tags": ["core", "framework", "foundation", "base"],
  "dependencies": [],
  "tools": [
    {
      "name": "load_skill",
      "description": "Load a skill by name and initialize it",
      "parameters": {
        "skill_name": {
          "type": "string",
          "description": "Name of the skill to load",
          "required": true
        }
      }
    },
    {
      "name": "list_available_skills",
      "description": "List all available skills in the system",
      "parameters": {}
    },
    {
      "name": "get_skill_info",
      "description": "Get detailed information about a skill",
      "parameters": {
        "skill_name": {
          "type": "string",
          "description": "Name of the skill",
          "required": true
        }
      }
    },
    {
      "name": "execute_tool",
      "description": "Execute a specific tool from a skill",
      "parameters": {
        "skill_name": {
          "type": "string",
          "description": "Name of the skill",
          "required": true
        },
        "tool_name": {
          "type": "string",
          "description": "Name of the tool to execute",
          "required": true
        },
        "parameters": {
          "type": "object",
          "description": "Tool parameters",
          "required": false
        }
      }
    },
    {
      "name": "get_config",
      "description": "Get configuration value by key",
      "parameters": {
        "key": {
          "type": "string",
          "description": "Configuration key (supports dot notation)",
          "required": true
        }
      }
    },
    {
      "name": "set_config",
      "description": "Set configuration value",
      "parameters": {
        "key": {
          "type": "string",
          "description": "Configuration key",
          "required": true
        },
        "value": {
          "type": "string",
          "description": "Configuration value",
          "required": true
        }
      }
    },
    {
      "name": "get_project_info",
      "description": "Get project information and status",
      "parameters": {}
    },
    {
      "name": "register_handler",
      "description": "Register an event handler for skill events",
      "parameters": {
        "event": {
          "type": "string",
          "description": "Event name to listen for",
          "required": true
        },
        "handler": {
          "type": "string",
          "description": "Handler function name",
          "required": true
        }
      }
    }
  ]
}
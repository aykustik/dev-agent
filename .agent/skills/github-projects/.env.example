# GitHub Token (benötigt repo, project Berechtigungen)
GH_TOKEN=

# GitHub Project ID (findest du in der URL: github.com/users/USER/projects/ID)
DEFAULT_PROJECT_ID=

# Optional: Standard-Branch
DEFAULT_BRANCH=main

# Optional: Arbeitsverzeichnis
WORKSPACE_DIR=

# Optional: Skill-spezifische Einstellungen
SKILL_LOG_LEVEL=info